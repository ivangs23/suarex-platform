# Rellenar con `pnpm db:env` tras `pnpm db:start`
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Mismos valores que SUPABASE_URL / SUPABASE_ANON_KEY, expuestos al navegador
# (prefijo NEXT_PUBLIC_) para el cliente de sesión del personal. La anon key es
# pública por diseño; RLS es lo que acota qué ve cada usuario. Nunca añadas un
# NEXT_PUBLIC_SUPABASE_SERVICE_ROLE_KEY: esa clave jamás debe llegar al navegador.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Dominios raíz para resolver subdominios de tenant, separados por coma
TENANT_ROOT_DOMAINS=localhost,suarex.app
