{
  "name": "suarex-platform",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "typecheck": "turbo typecheck && pnpm typecheck:tests",
    "typecheck:tests": "tsc --noEmit -p tests/tsconfig.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "db:start": "supabase start",
    "db:reset": "supabase db reset",
    "db:env": "node scripts/write-test-env.mjs",
    "seed:staff": "node scripts/seed-staff.mjs",
    "test:integration": "vitest run --config vitest.config.ts",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@playwright/test": "^1.61.1",
    "@suarex/agent": "workspace:*",
    "@suarex/db": "workspace:*",
    "@suarex/printing": "workspace:*",
    "@suarex/ticket": "workspace:*",
    "@supabase/supabase-js": "^2.110.7",
    "@types/node": "^26.1.1",
    "dotenv": "^17.4.2",
    "turbo": "^2.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
