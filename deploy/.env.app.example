# Copiar a `deploy/.env.app` EN EL VPS y rellenar. Este fichero (el .example) sí va al
# repo; `.env.app` está en .gitignore y en .dockerignore y no debe salir del servidor.
#
#   cp deploy/.env.app.example deploy/.env.app && chmod 600 deploy/.env.app

# --- Dominio -----------------------------------------------------------------------
# Sin protocolo y sin punto inicial. De aquí salen `*.PLATFORM_DOMAIN` (un subdominio por
# cliente) y `api.PLATFORM_DOMAIN`.
PLATFORM_DOMAIN=suarex.app

# Dominios raíz que `proxy.ts` acepta para resolver el tenant por Host. Separados por coma.
# Debe incluir PLATFORM_DOMAIN; añade otros si sirves más de un dominio.
TENANT_ROOT_DOMAINS=suarex.app

# Avisos de caducidad de certificado de Let's Encrypt.
ACME_EMAIL=tu-correo@ejemplo.com

# Token de API de Cloudflare para el challenge DNS-01 del certificado comodín.
# Permisos MÍNIMOS: Zone / DNS / Edit, restringido a la zona de PLATFORM_DOMAIN.
# No uses la Global API Key: da acceso a toda tu cuenta.
CLOUDFLARE_API_TOKEN=

# --- Supabase ----------------------------------------------------------------------
# Las tres claves salen del `.env` de la stack de Supabase (ANON_KEY, SERVICE_ROLE_KEY),
# generadas con el JWT_SECRET del servidor. Ver README, paso 4.

# URL pública de la API. Se usa TANTO en el navegador como en el servidor: apuntar el
# servidor a `http://kong:8000` ahorraría un salto por Caddy, pero deja dos orígenes
# distintos para la misma sesión y las cookies de auth dejan de cuadrar. Un solo origen.
SUPABASE_URL=https://api.suarex.app
NEXT_PUBLIC_SUPABASE_URL=https://api.suarex.app

# Pública por diseño: viaja al navegador y RLS es lo que acota qué ve cada usuario.
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SECRETO. Salta RLS por completo: quien la tenga lee y escribe los datos de TODOS los
# clientes. Vive solo aquí, en el servidor.
#   - nunca con prefijo NEXT_PUBLIC_ (acabaría en el bundle del navegador)
#   - nunca en el instalador del agente de escritorio (ese solo lleva la anon key)
#   - nunca en un ARG de build de Docker (quedaría en una capa de la imagen)
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ------------------------------------------------------------------------
# Claves de PRODUCCIÓN (sk_live_..., whsec_...). El endpoint del webhook se configura en
# el panel de Stripe apuntando a https://<cliente>.suarex.app/api/stripe/webhook
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
